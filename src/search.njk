---
permalink: /search/
title: Search Games
robots: noindex, follow
---
{# Search page — noindex (infinite query combinations must not be indexed).
   Client-side filtering over a SLIM projection of the games data (name/tagline/
   category/tags only — no about/howToPlay/sourceUrl inlined). Results are built
   with safe DOM APIs (textContent), never string-concatenated into innerHTML,
   because the name/tagline originate from imported upstream data. #}

{% extends 'base.njk' %}

{% block adsense %}{% endblock %}
{# No AdSense on this page (issue #15). #}

{% block content %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <header class="mb-8">
        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">Search Games</h1>
        <p class="text-white/70 mt-2">Find games by name, category or tag.</p>
    </header>

    <form id="search-form" class="mb-8">
        <input type="search" name="q" id="search-q" placeholder="Type a game name, category or tag…"
            class="w-full px-5 py-3 rounded-full border-0 bg-white/10 text-lg focus:outline-none focus:ring-2 focus:ring-fuchsia-400/60"
            autocomplete="off">
    </form>

    <div id="search-results" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        {# Results rendered client-side below; this is the no-JS fallback list #}
        {% for game in games | limit(12) %}
        <noscript>
            <a href="/game/{{ game.slug }}/" class="panel-card p-4 block">
                <h3 class="font-semibold">{{ game.name }}</h3>
                <p class="text-sm text-white/60 mt-1">{{ game.tagline }}</p>
            </a>
        </noscript>
        {% endfor %}
    </div>

    <div id="search-empty" class="hidden panel-card p-12 text-center mt-4">
        <p class="text-white/60">No games match your search.</p>
    </div>

</div>

<script>
(function () {
    // Slim projection — only the matched fields (extend.md §5.4.2).
    var games = {{ games | toSearchIndex | safe }};
    var input = document.getElementById('search-q');
    var results = document.getElementById('search-results');
    var empty = document.getElementById('search-empty');

    // Build a card with safe DOM APIs. name/tagline are imported upstream text,
    // so they go through textContent (never innerHTML) — no injection surface.
    function card(g) {
        var a = document.createElement('a');
        a.href = '/game/' + g.slug + '/';
        a.className = 'panel-card p-4 flex flex-col gap-3 hover:border-white/20 transition';

        var body = document.createElement('div');
        var h3 = document.createElement('h3');
        h3.className = 'font-semibold text-lg leading-tight';
        h3.textContent = g.name;
        body.appendChild(h3);

        var p = document.createElement('p');
        p.className = 'text-sm text-white/60 mt-1';
        p.textContent = g.tagline || '';
        body.appendChild(p);
        a.appendChild(body);

        var badge = document.createElement('span');
        badge.className = 'badge mt-auto';
        badge.textContent = g.category;
        a.appendChild(badge);
        return a;
    }

    function render(q) {
        q = (q || '').trim().toLowerCase();
        var filtered = !q ? games.slice(0, 24) : games.filter(function (g) {
            return (g.name && g.name.toLowerCase().indexOf(q) > -1)
                || (g.tagline && g.tagline.toLowerCase().indexOf(q) > -1)
                || (g.category && g.category.toLowerCase().indexOf(q) > -1)
                || (Array.isArray(g.tags) && g.tags.join(' ').toLowerCase().indexOf(q) > -1);
        });
        results.innerHTML = ''; // clear (incl. noscript fallback once JS runs)
        filtered.slice(0, 48).forEach(function (g) { results.appendChild(card(g)); });
        empty.classList.toggle('hidden', filtered.length > 0);
    }

    var params = new URLSearchParams(window.location.search);
    input.value = params.get('q') || '';
    render(input.value);
    input.addEventListener('input', function () { render(input.value); });
})();
</script>
{% endblock %}
