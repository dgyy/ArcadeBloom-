---
permalink: /search/
title: Search Games
robots: noindex, follow
---
{# Search page — noindex (infinite query combinations must not be indexed).
   Client-side filtering over the games data. Query-param driven (?q=). #}

{% extends 'base.njk' %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <header class="mb-8">
        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">Search Games</h1>
        <p class="text-white/70 mt-2">Find games by name, category or tag.</p>
    </header>

    <form id="search-form" class="mb-8">
        <input type="search" name="q" id="search-q" placeholder="Type a game name, category or tag…"
            class="w-full px-5 py-3 rounded-full border-0 bg-white/10 text-lg focus:outline-none focus:ring-2 focus:ring-fuchsia-400/60"
            autocomplete="off">
    </form>

    <div id="search-results" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        {# Results rendered client-side below; this is the no-JS fallback list #}
        {% for game in games | limit(12) %}
        <noscript>
            <a href="/game/{{ game.slug }}/" class="panel-card p-4 block">
                <h3 class="font-semibold">{{ game.name }}</h3>
                <p class="text-sm text-white/60 mt-1">{{ game.tagline }}</p>
            </a>
        </noscript>
        {% endfor %}
    </div>

    <div id="search-empty" class="hidden panel-card p-12 text-center mt-4">
        <p class="text-white/60">No games match your search.</p>
    </div>

</div>

<script>
(function () {
    var games = {{ games | toJSON | safe }};
    var input = document.getElementById('search-q');
    var results = document.getElementById('search-results');
    var empty = document.getElementById('search-empty');

    function card(g) {
        return '<a href="/game/' + g.slug + '/" class="panel-card p-4 flex flex-col gap-3 hover:border-white/20 transition">'
             + '<div><h3 class="font-semibold text-lg leading-tight">' + g.name + '</h3>'
             + '<p class="text-sm text-white/60 mt-1">' + (g.tagline || '') + '</p></div>'
             + '<span class="badge mt-auto">' + g.category + '</span></a>';
    }

    function render(q) {
        q = (q || '').trim().toLowerCase();
        var filtered = !q ? games.slice(0, 24) : games.filter(function (g) {
            return (g.name && g.name.toLowerCase().indexOf(q) > -1)
                || (g.tagline && g.tagline.toLowerCase().indexOf(q) > -1)
                || (g.category && g.category.toLowerCase().indexOf(q) > -1)
                || (Array.isArray(g.tags) && g.tags.join(' ').toLowerCase().indexOf(q) > -1);
        });
        results.innerHTML = filtered.slice(0, 48).map(card).join('');
        empty.classList.toggle('hidden', filtered.length > 0);
    }

    var params = new URLSearchParams(window.location.search);
    input.value = params.get('q') || '';
    render(input.value);
    input.addEventListener('input', function () { render(input.value); });
})();
</script>
{% endblock %}
