---
pagination:
    data: paginatedLists.categoryPages
    size: 1
    alias: p
permalink: "{{ p.href }}"
eleventyComputed:
    robots: "{% if p.isFirst %}index, follow{% else %}noindex, follow{% endif %}"
---

{% extends 'base.njk' %}
{% set cat = site.categories | findCat(p.category) %}
{% set is_thin = p.totalGames < site.minGamesPerCategory %}

{% block title_tag %}<title>{{ cat.name }} Games — Browse {{ cat.name }} on ArcadeBloom{% if p.totalPages > 1 %} — Page {{ p.page }}{% endif %}</title>{% endblock %}
{% block meta_description %}<meta name="description" content="{{ cat.blurb }}">{% endblock %}

{% block jsonld %}
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"CollectionPage","name":{{ (cat.name ~ " Games") | toJSON | safe }},"description":{{ cat.blurb | toJSON | safe }},"url":"{{ site.url }}/category/{{ cat.slug }}/"}
</script>
{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 py-8">
    <nav class="text-sm text-white/60 mb-6">
        <a href="/">Home</a> / <span class="text-white">{{ cat.name }}</span>
    </nav>
    <header class="mb-10">
        <div class="flex items-center gap-3">
            <h1 class="text-4xl font-extrabold">{{ cat.name }} Games</h1>
            <span class="badge">{{ p.totalGames }}</span>
        </div>
        <p class="text-lg text-white/70 mt-4 max-w-3xl">{{ cat.intro }}</p>
    </header>
    {% if is_thin %}
    <div class="panel-card p-6 mb-8"><p class="text-sm">{{ p.totalGames }}/{{ site.minGamesPerCategory }} seeded.</p></div>
    {% endif %}

    {% include 'ad-banner.njk' %}

    {% if p.games.length %}
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        {% for game in p.games %}
        {% include 'game-card.njk' %}
        {% endfor %}
    </div>
    {% include 'pagination.njk' %}
    {% else %}
    <div class="panel-card p-12 text-center"><p>No games yet.</p></div>
    {% endif %}
</div>
{% endblock %}
