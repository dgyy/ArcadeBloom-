{# =============================================================================
   base.njk — shared page skeleton for every ArcadeBloom page.
   Editorial chrome: solid nav (no blur), Space Grotesk display + Inter body +
   Space Mono accents, hairline surfaces, accessible mobile menu (no JS).
   Per-page content goes in {% block content %}.
   ============================================================================= #}
<!DOCTYPE html>
<html lang="{{ locale or site.locale }}" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {# ---- SEO ---- #}
    {% block title_tag %}
    <title>{{ title }}{% if title_suffix is defined %}{{ title_suffix }}{% else %} — ArcadeBloom{% endif %}</title>
    {% endblock %}
    {% block meta_description %}
    <meta name="description" content="{{ description or site.description }}">
    {% endblock %}
    <meta name="author" content="ArcadeBloom">
    <meta name="robots" content="{{ robots or 'index, follow' }}">
    <meta name="google-adsense-account" content="ca-pub-1115845392526625">

    <link rel="canonical" href="{{ canonical or (page.url | absoluteUrl) }}">

    {# ---- Open Graph ---- #}
    <meta property="og:title" content="{{ og_title or title }}">
    <meta property="og:description" content="{{ description or site.description }}">
    <meta property="og:type" content="{{ og_type or 'website' }}">
    <meta property="og:url" content="{{ canonical or (page.url | absoluteUrl) }}">
    <meta property="og:image" content="{{ site.url }}/og-image.png">
    <meta property="og:site_name" content="ArcadeBloom">

    {# ---- Twitter ---- #}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ og_title or title }}">
    <meta name="twitter:description" content="{{ description or site.description }}">
    <meta name="twitter:image" content="{{ site.url }}/og-image.png">

    {# ---- Favicon (PNG-content .ico + SVG master + apple-touch) ---- #}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

    {# ---- Fonts: Space Grotesk (display) + Inter (body) + Space Mono (accents).
          One combined request, display=swap to avoid FOIT. ~22KB extra vs
          body-only — acceptable for a content-first editorial type system. ---- #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

    {# ---- Compiled CSS (Tailwind utilities + custom design tokens).
          Built by `npm run build:css` into /css/styles.css — no CDN, no FOUC.
          The ?v= query busts the browser/CDN cache on every deploy
          (asset_version is a build timestamp; see .eleventy.js). ---- #}
    <link rel="stylesheet" href="/css/styles.css?v={{ asset_version }}">

    {# ---- Google AdSense ---- #}
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1115845392526625" crossorigin="anonymous"></script>

    {# ---- Structured data (per-page override via {% block jsonld %}) ---- #}
    {% block jsonld %}{% endblock %}
</head>
<body class="font-body">

<a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:px-4 focus:py-2 focus:bg-bloom focus:text-ink focus:rounded-full focus:font-semibold">Skip to content</a>

<header class="nav-shell sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-4 h-16">
            {% include 'brand-mark.njk' %}

            {# Desktop category nav — only categories meeting the thin-content
               threshold appear in the header; all six remain in the footer. #}
            <nav class="hidden lg:flex items-center gap-1 ml-4" aria-label="Categories">
                {% for cat in site.categories %}
                {% set cat_count = games | whereEq('category', cat.slug) | length %}
                {% if cat_count >= site.minGamesPerCategory %}
                <a href="/category/{{ cat.slug }}/" class="cat-{{ cat.slug }} px-3 py-1.5 text-sm font-medium text-paper-70 hover:text-bloom rounded-full transition-colors">
                    {{ cat.name }}
                </a>
                {% endif %}
                {% endfor %}
            </nav>

            <div class="flex-1"></div>

            {# Desktop inline search (compact) #}
            <div class="hidden md:block w-56 lg:w-64">
                {% set size = 'sm' %}
                {% include 'search-inline.njk' %}
            </div>

            {# Mobile: Browse dropdown (no JS — details/summary) #}
            <details class="mobile-nav relative md:hidden">
                <summary class="btn-ghost !px-3 !py-2 text-sm" aria-label="Browse categories">
                    Browse
                    <svg class="mobile-nav__chevron w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="m5 7.5 5 5 5-5" /></svg>
                </summary>
                <div class="absolute right-0 top-full mt-2 w-64 surface rounded-2xl overflow-hidden shadow-xl shadow-black/40">
                    <a href="/featured/" class="block px-4 py-2.5 text-sm text-paper-70 hover:text-bloom hover:bg-ink-3 transition-colors">Featured</a>
                    <a href="/new/" class="block px-4 py-2.5 text-sm text-paper-70 hover:text-bloom hover:bg-ink-3 transition-colors">New Arrivals</a>
                    <div class="hairline-top mx-2 my-1"></div>
                    {% for cat in site.categories %}
                    <a href="/category/{{ cat.slug }}/" class="cat-{{ cat.slug }} flex items-center gap-2 px-4 py-2.5 text-sm text-paper-70 hover:bg-ink-3 transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-[var(--cat)]"></span>
                        {{ cat.name }}
                    </a>
                    {% endfor %}
                    <div class="hairline-top mx-2 my-1"></div>
                    <form action="/search/" method="get" class="p-3">
                        <label for="q-mobile" class="sr-only">Search games</label>
                        <input id="q-mobile" type="search" name="q" placeholder="Search games…"
                            value="{{ search_q or '' }}" autocomplete="off"
                            class="w-full bg-ink-3 border border-[var(--hairline-strong)] px-3 py-2 text-sm rounded-full focus:outline-none focus:border-bloom placeholder:text-paper-45">
                    </form>
                </div>
            </details>
        </div>
    </div>
</header>

<main id="main">
{% block content %}{% endblock %}
</main>

<footer class="hairline-top mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
        <div class="grid grid-cols-2 md:grid-cols-12 gap-10">
            <div class="col-span-2 md:col-span-5">
                {% include 'brand-mark.njk' %}
                <p class="text-paper-60 text-sm leading-relaxed mt-4 max-w-sm">{{ site.description }}</p>
                <p class="eyebrow mt-6">A directory · we review, you play at the source</p>
            </div>

            <div class="md:col-span-3 md:col-start-7">
                <h3 class="eyebrow mb-4">Browse</h3>
                <ul class="space-y-2.5 text-sm">
                    <li><a href="/featured/" class="text-paper-70 hover:text-bloom transition-colors">Featured</a></li>
                    <li><a href="/new/" class="text-paper-70 hover:text-bloom transition-colors">New</a></li>
                    {% for cat in site.categories %}
                    <li><a href="/category/{{ cat.slug }}/" class="cat-{{ cat.slug }} text-paper-70 hover:text-bloom transition-colors">{{ cat.name }}</a></li>
                    {% endfor %}
                </ul>
            </div>

            <div class="md:col-span-3">
                <h3 class="eyebrow mb-4">Company</h3>
                <ul class="space-y-2.5 text-sm">
                    {% for link in site.footerLinks %}
                    <li><a href="{{ link.href }}" class="text-paper-70 hover:text-bloom transition-colors">{{ link.label }}</a></li>
                    {% endfor %}
                </ul>
            </div>
        </div>

        <div class="hairline-top mt-12 pt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
            <p class="font-mono text-xs text-paper-45">© 2026 ArcadeBloom · est. 2026</p>
            <p class="font-mono text-xs text-paper-45">{{ games | length }} games catalogued and growing</p>
        </div>
    </div>
</footer>

{# ---- Per-page footer scripts (deferred, measurement-only) ---- #}
{% block scripts %}{% endblock %}

</body>
</html>
