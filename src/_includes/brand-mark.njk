{# brand-mark.njk — ArcadeBloom wordmark + bloom glyph.
   Reused in header, footer, and OG image. No glassmorphic container.
   The glyph is a 6-petal bloom — a quiet nod to the 6 top-level categories.
   Variables:
     wordmark_class — classes applied to the wordmark span (default size set by caller)
     glyph_class    — classes applied to the svg (default w-8 h-8)
 #}
<a href="/" class="flex items-center gap-2.5 group">
    <svg class="{{ glyph_class or 'w-8 h-8' }} text-bloom" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        {# 6 petals arranged radially around a center seed #}
        <g fill="currentColor">
            <ellipse cx="16" cy="6"  rx="3.2" ry="6" />
            <ellipse cx="16" cy="6"  rx="3.2" ry="6" transform="rotate(60 16 16)" />
            <ellipse cx="16" cy="6"  rx="3.2" ry="6" transform="rotate(120 16 16)" />
            <ellipse cx="16" cy="6"  rx="3.2" ry="6" transform="rotate(180 16 16)" />
            <ellipse cx="16" cy="6"  rx="3.2" ry="6" transform="rotate(240 16 16)" />
            <ellipse cx="16" cy="6"  rx="3.2" ry="6" transform="rotate(300 16 16)" />
        </g>
        <circle cx="16" cy="16" r="3.4" fill="#0e0b16" />
        <circle cx="16" cy="16" r="1.6" fill="#f5efe2" />
    </svg>
    <span class="font-display font-bold tracking-tight {{ wordmark_class or 'text-xl' }}">
        Arcade<span class="text-bloom">Bloom</span>
    </span>
</a>
