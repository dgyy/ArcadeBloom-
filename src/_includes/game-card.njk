{# Reusable game card. Expects `game` in scope. Links to /game/<slug>/.
   When a screenshot exists, show it; otherwise a category-tinted gradient
   placeholder that reads as deliberate design, not a missing-image gap. #}
<a href="/game/{{ game.slug }}/" class="panel-card overflow-hidden hover:scale-[1.02] hover:border-white/20 transition group flex flex-col">
    {% if game.screenshots and game.screenshots.length %}
    <div class="aspect-video bg-white/5 overflow-hidden">
        <img src="{{ game.screenshots[0] }}" alt="{{ game.name }} screenshot"
             loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition">
    </div>
    {% else %}
    {% set cat_colors = { 'puzzle': 'from-violet-500/40 to-fuchsia-400/30', 'action': 'from-rose-500/40 to-orange-400/30', 'arcade': 'from-sky-500/40 to-cyan-400/30', 'strategy': 'from-amber-500/40 to-yellow-400/30', 'racing-sports': 'from-emerald-500/40 to-teal-400/30', 'simulation': 'from-indigo-500/40 to-blue-400/30' } %}
    <div class="aspect-video bg-gradient-to-br {{ cat_colors[game.category] or 'from-fuchsia-500/30 to-sky-400/30' }} flex items-center justify-center relative">
        <span class="text-5xl font-extrabold text-white/20 select-none">{{ game.name | first | upper }}</span>
        <span class="absolute bottom-2 right-3 text-[10px] uppercase tracking-wider text-white/30">{{ game.category }}</span>
    </div>
    {% endif %}
    <div class="p-4 flex flex-col gap-2 flex-1">
        <h3 class="font-semibold text-lg leading-tight group-hover:text-white">{{ game.name }}</h3>
        {% if game.tagline %}
        <p class="text-sm text-white/60 line-clamp-2">{{ game.tagline }}</p>
        {% endif %}
        <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
            {% if game.screenshots and game.screenshots.length %}
            <span class="badge">{{ game.category }}</span>
            {% endif %}
        </div>
    </div>
</a>
