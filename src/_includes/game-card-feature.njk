{# game-card-feature.njk — large variant for the Editor's Picks hero slot.
   Expects `game` in scope. Bigger image, prominent tagline, "Review →" CTA.
   Solid surface, category-accent hairline on the left edge.
 #}
<a href="/game/{{ game.slug }}/" class="cat-{{ game.category }} group relative flex flex-col surface-raised overflow-hidden transition-transform hover:-translate-y-0.5">
    {# Accent edge — a 3px bar on the left in the category color #}
    <span class="absolute left-0 top-0 bottom-0 w-[3px] bg-[var(--cat)] opacity-60 group-hover:opacity-100 transition-opacity"></span>

    {% if game.screenshots and game.screenshots.length %}
    <div class="aspect-[16/10] bg-ink-3 overflow-hidden relative">
        <img src="{{ game.screenshots[0] }}" alt="{{ game.name }} screenshot"
             {% if lazy != false %}loading="lazy"{% endif %}
             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
    </div>
    {% else %}
    <div class="aspect-[16/10] bg-gradient-to-br from-[var(--cat)]/25 to-ink-3 flex items-center justify-center">
        <span class="font-display text-7xl font-bold text-paper/15 select-none">{{ game.name | first | upper }}</span>
    </div>
    {% endif %}

    <div class="flex flex-col gap-3 p-5 md:p-6 flex-1">
        <div class="flex items-center gap-2 flex-wrap">
            <span class="cat-chip">{{ game.category }}</span>
            {% if game.featured %}<span class="badge">Editor's Pick</span>{% endif %}
        </div>
        <h3 class="display-h2 text-2xl md:text-3xl">{{ game.name }}</h3>
        {% if game.tagline %}
        <p class="text-paper-70 text-base leading-relaxed">{{ game.tagline }}</p>
        {% endif %}
        <span class="mt-auto inline-flex items-center gap-1.5 text-sm font-semibold text-bloom pt-2">
            Read review <span aria-hidden="true">→</span>
        </span>
    </div>
</a>
