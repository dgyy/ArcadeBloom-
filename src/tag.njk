---
pagination:
    data: paginatedLists.tagPages
    size: 1
    alias: p
permalink: "{{ p.href }}"
eleventyComputed:
    robots: "{% if p.isFirst %}index, follow{% else %}noindex, follow{% endif %}"
---

{% extends 'base.njk' %}

{% set tag = tags | findTag(p.tag) %}

{% block title_tag %}<title>{{ tag.name }} Games — ArcadeBloom{% if p.totalPages > 1 %} — Page {{ p.page }}{% endif %}</title>{% endblock %}
{% block meta_description %}<meta name="description" content="{{ tag.description }}">{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 py-8">
    <nav class="text-sm text-white/60 mb-6"><a href="/">Home</a> / <span class="text-white">{{ tag.name }}</span></nav>
    <header class="mb-10">
        <div class="flex items-center gap-3">
            <h1 class="text-4xl font-extrabold">{{ tag.name }}</h1>
            <span class="badge">{{ p.totalGames }}</span>
        </div>
        <p class="text-lg text-white/70 mt-4 max-w-3xl">{{ tag.description }}</p>
    </header>

    {% include 'ad-banner.njk' %}

    {% if p.games.length %}
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        {% for game in p.games %}{% include 'game-card.njk' %}{% endfor %}
    </div>
    {% include 'pagination.njk' %}
    {% else %}
    <div class="panel-card p-12 text-center"><p>No games yet.</p></div>
    {% endif %}
</div>
{% endblock %}
