---
pagination:
    data: collections
    size: 1
    alias: collection
permalink: "/collection/{{ collection.slug }}/"
eleventyComputed:
    title: "{{ collection.title }} — ArcadeBloom Collection"
    description: "{{ collection.thesis }}"
    robots: "index, follow"
---

{% extends 'base.njk' %}

{% block jsonld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ collection.title | toJSON | safe }},
  "description": {{ collection.thesis | toJSON | safe }},
  "itemListElement": [
    {% for slug in collection.games %}
    {% set g = games | whereEq('slug', slug) | first %}
    {% if g %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "url": "{{ site.url }}/game/{{ g.slug }}/",
      "name": {{ g.name | toJSON | safe }}
    }{% if not loop.last %},{% endif %}
    {% endif %}
    {% endfor %}
  ]
}
</script>
{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <nav class="text-sm text-white/60 mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-2">/</span>
        <span class="text-white">Collection</span>
    </nav>

    <article>
        <p class="eyebrow mb-3">Editorial Collection</p>
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">{{ collection.title }}</h1>
        <p class="text-lg text-white/70 leading-relaxed mb-10">{{ collection.thesis }}</p>

        {# Editorial synthesis — the "how to choose" paragraph.
           Card-only pages fail validation; this block is mandatory. #}
        <section class="surface rounded-2xl p-6 mb-10">
            <h2 class="text-xl font-bold mb-3">How to choose</h2>
            <p class="text-white/80 leading-relaxed">{{ collection.synthesis }}</p>
        </section>

        {# Games with distinct per-game comparisons — not a bare card grid. #}
        <section class="space-y-6 mb-12">
            <h2 class="display-h2 text-2xl md:text-3xl mb-4">The games</h2>
            {% for slug in collection.games %}
            {% set g = games | whereEq('slug', slug) | first %}
            {% if g %}
            {% set comparison = collection.comparisons[loop.index0] %}
            <article class="surface rounded-2xl p-6">
                <div class="flex items-start justify-between gap-4 mb-3">
                    <div>
                        <h3 class="text-lg font-bold">
                            <a href="/game/{{ g.slug }}/" class="hover:text-bloom transition-colors">{{ g.name }}</a>
                        </h3>
                        <p class="text-sm text-paper-45">{{ g.sourceName }} · {{ g.licence }}</p>
                    </div>
                    <span class="cat-{{ g.category }} eyebrow whitespace-nowrap">{{ site.categories | findCat(g.category) | first | default(g.category) }}</span>
                </div>
                <p class="text-white/80 text-sm leading-relaxed">{{ comparison }}</p>
            </article>
            {% endif %}
            {% endfor %}
        </section>

        {# Evidence references — every factual claim points at a record. #}
        <section class="hairline-top pt-6">
            <h2 class="eyebrow mb-3">Evidence</h2>
            <p class="text-xs text-paper-45 leading-relaxed">
                Every claim in this Collection is backed by an evidence record. Sources:
            </p>
            <ul class="text-xs text-paper-60 mt-2 space-y-1">
                {% for ref in collection.evidenceRefs %}
                <li class="font-mono">{{ ref }}</li>
                {% endfor %}
            </ul>
        </section>
    </article>

</div>
{% endblock %}
